# PostgreSQL password
DB_PASSWORD=change_me

# JWT signing secret — use a random string of at least 32 characters
JWT_SECRET=change_me_to_a_long_random_string

# Initial admin account created on first boot
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me

# Port the app is exposed on (default: 3003)
PORT=3003

# URL the frontend is served from — used for CORS (default: http://localhost)
FRONTEND_URL=http://localhost:3003

# Public URL of the app — used in password reset emails
APP_URL=http://localhost:3003

# Optional: Jira integration
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
# Story points custom field ID (default: auto-detected, fallback: customfield_10016)
JIRA_STORY_POINTS_FIELD=
# Epic Link custom field ID (default: auto-detected, fallback: customfield_10014)
JIRA_EPIC_LINK_FIELD=
# Project key(s) that hold PROD items (default: derived from planned prod_id values, fallback: PROD)
JIRA_PROD_PROJECT_KEY=
# Statuses treated as cancelled/excluded (comma-separated; default: Obsolete / Won't Do + common variants)
JIRA_EXCLUDED_STATUSES=

# Optional: SMTP for password reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
